{
  "openapi": "3.0.3",
  "info": {
    "title": "MarketInsight S.A. Inventory and Mobile Hardware Scraper API",
    "description": "Enterprise-grade microservice simulation REST API for MarketInsight S.A., providing fully structural cellphone catalog data scraped and unified from various retail competitors matching the institutional template of 'Tienda Amiga'. This service is prepared for transactional integration, data warehouse merging, and hardware competitive analysis.",
    "version": "1.0.0",
    "contact": {
      "name": "MarketInsight Hardware Integrity Team",
      "email": "hardware-integrity@marketinsight.corp"
    }
  },
  "servers": [
    {
      "url": "/api",
      "description": "Local proxy and service entrypoint"
    }
  ],
  "paths": {
    "/inventario": {
      "get": {
        "summary": "Retrieve unified cellphone catalog",
        "description": "Fetches a collection of structural mobile phone records containing advanced specifications and retail mock prices mapped for MarketInsight S.A. matching standard competitive schema parameters.",
        "parameters": [
          {
            "name": "marca",
            "in": "query",
            "description": "Filter items by manufacturer uppercase brand logo",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["APPLE", "SAMSUNG", "MOTOROLA", "XIAOMI", "ONEPLUS", "HONOR", "INFINIX", "TECNO"]
            }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Fuzzy matching string to filter catalog by title, processor, or storage parameters",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful retrieval of structural unified cell phone database",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CellphoneProduct"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Check API container health",
        "description": "Returns operational status parameters of the MarketInsight S.A. microservice container instance.",
        "responses": {
          "200": {
            "description": "Service is operational and matching standard execution times",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "online"
                    },
                    "service": {
                      "type": "string",
                      "example": "MarketInsight Inventory API"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CellphoneProduct": {
        "type": "object",
        "required": [
          "title",
          "price",
          "quotes",
          "url",
          "Marca",
          "Modelo",
          "Color",
          "Diseno",
          "Pantalla",
          "Resolucion",
          "Camara",
          "Procesador",
          "Memoria",
          "Bateria",
          "Sensores",
          "Dimensiones",
          "Peso",
          "Conectividad",
          "Sistema_Operativo",
          "Video",
          "Redes",
          "Garantia"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "Full commercial title scraped from listing",
            "example": "Celular Xiaomi Redmi 15 8+256gb Negro"
          },
          "price": {
            "type": "string",
            "description": "Retail checkout price matching actual currency representation",
            "example": "2.099,00 Bs."
          },
          "quotes": {
            "type": "string",
            "description": "Available mock payment installment plan constraints",
            "example": "en 3 cuotas de 819 Bs"
          },
          "url": {
            "type": "string",
            "description": "Direct listing link simulation",
            "example": "https://www.tiendaamiga.com.bo/la_paz/celular-xiaomi-redmi-15"
          },
          "Marca": {
            "type": "string",
            "example": "XIAOMI"
          },
          "Modelo": {
            "type": "string",
            "description": "Specific device series model identifier",
            "example": "15"
          },
          "Color": {
            "type": "string",
            "description": "Commercial color casing definition",
            "example": "Negro"
          },
          "Diseno": {
            "type": "string",
            "description": "Form factor and build materials",
            "example": "Delgado"
          },
          "Pantalla": {
            "type": "string",
            "description": "Screen panel engineering technology and size dimensions",
            "example": "Pantalla DotDisplay FHD+ de 6,9\""
          },
          "Resolucion": {
            "type": "string",
            "description": "Pixel density and resolution stats",
            "example": "2340 x 1080"
          },
          "Camara": {
            "type": "string",
            "description": "Camera layout configurations",
            "example": "Cámara Frontal 8 MP Cámara Principal 50 MP"
          },
          "Procesador": {
            "type": "string",
            "description": "SoC chipset built into device",
            "example": "Snapdragon® 685"
          },
          "Memoria": {
            "type": "string",
            "description": "Combined random-access memory and cold storage layout",
            "example": "Memoria RAM 8 GB Almacenamiento 256 GB"
          },
          "Bateria": {
            "type": "string",
            "description": "Nominal power cell storage capacity",
            "example": "7000 mAh"
          },
          "Sensores": {
            "type": "string",
            "description": "Included hardware sensors",
            "example": "Sensor de proximidad virtual, Sensor de luz ambiental"
          },
          "Dimensiones": {
            "type": "string",
            "description": "Physical chassis height, width, and thickness parameters",
            "example": "Alto 17.15 x Ancho 7.94 x Profundidad 0.79 cm"
          },
          "Peso": {
            "type": "string",
            "description": "Chassis weight",
            "example": "224 g"
          },
          "Conectividad": {
            "type": "string",
            "description": "Scraped wireless frequency bands and standards supported",
            "example": "SIM 1 e híbrida (SIM o microSD)"
          },
          "Sistema_Operativo": {
            "type": "string",
            "description": "Operating system and native major release version",
            "example": "Android 11 Hypers OS"
          },
          "Video": {
            "type": "string",
            "description": "Video recording capabilities",
            "example": "4K a 30 fps. 1080p a 30/60/120/240/960 fps"
          },
          "Redes": {
            "type": "string",
            "description": "Mobile network frequencies",
            "example": "GSM/HSPA/LTE/5G"
          },
          "Garantia": {
            "type": "string",
            "description": "Official local consumer warranty coverage period",
            "example": "12 Meses"
          }
        }
      }
    }
  }
}
